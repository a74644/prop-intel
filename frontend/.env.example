# PropIntelligence Frontend — environment variable template
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit your actual token.

# Mapbox public token (starts with pk.)
# Get yours free at: https://account.mapbox.com/
# Required for map views in Search, Nearby, and Property Detail pages.
VITE_MAPBOX_TOKEN=pk.replace_with_your_public_token
