# ── PropIntelligence — environment variable template ──────────────────────────
# Copy this file to .env and fill in real values.
# The .env file is gitignored — never commit real secrets.

# SQL Server SA password (used by both the sqlserver container and the API connection string)
SA_PASSWORD=YourStrong!Password123

# JWT signing secret — must be at least 32 characters for HS256
# Generate a strong value with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Admin account seeding
# The API will create this admin account on first startup if it doesn't exist yet.
# Required — without these the admin account will NOT be created and a warning will be logged.
# Use a strong password: min 12 chars, mixed case + digits + symbols recommended.
ADMIN_EMAIL=admin@propintelligence.local
ADMIN_PASSWORD=replace-with-strong-admin-password
