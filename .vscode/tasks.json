{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet build ${workspaceFolder}/PropIntelligence.sln --configuration Debug",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "watch",
      "type": "shell",
      "command": "dotnet watch --project ${workspaceFolder}/src/PropIntelligence.API/PropIntelligence.API.csproj",
      "problemMatcher": "$msCompile",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "test",
      "type": "shell",
      "command": "dotnet test ${workspaceFolder}/PropIntelligence.sln --logger console;verbosity=normal",
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "docker: start sqlserver",
      "type": "shell",
      "command": "docker compose up -d sqlserver",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "docker: start all",
      "type": "shell",
      "command": "docker compose up -d --build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "docker: stop",
      "type": "shell",
      "command": "docker compose down",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "ef: update database",
      "type": "shell",
      "command": "dotnet ef database update --project src/PropIntelligence.Infrastructure --startup-project src/PropIntelligence.API",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "ef: add migration",
      "type": "shell",
      "command": "dotnet ef migrations add ${input:migrationName} --project src/PropIntelligence.Infrastructure --startup-project src/PropIntelligence.API",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ],
  "inputs": [
    {
      "id": "migrationName",
      "type": "promptString",
      "description": "Migration name (e.g. AddSuburbIndex)"
    }
  ]
}
